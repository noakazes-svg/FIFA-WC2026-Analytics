# FIFA World Cup 2026 — Environment Variables
# Copy this file to .env and fill in any optional values.
# No API keys are required for basic operation.

# Optional: football-data.org API key for backup results source
# Free tier at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# Optional: Slack webhook for update notifications
# Create at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Optional: override default log timezone
# Default is UTC. Example: America/New_York
REPORT_TIMEZONE=UTC

# GitHub Actions sets these automatically — do not set manually
GITHUB_ACTIONS=
GITHUB_REPOSITORY=
